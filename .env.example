# ================================================================
# private-internet — unified .env
# Copy this file to .env and fill in the real values.
# ================================================================

# ── Database (AWS RDS PostgreSQL with pgvector) ─────────────────
DB_HOST=your-rds-endpoint.eu-central-1.rds.amazonaws.com
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# ── Auth ────────────────────────────────────────────────────────
# Password shown at /api/oauth/authorize before any OAuth code is issued.
# REQUIRED in production — leave empty only for local dev (disables gate).
DASHBOARD_PASSWORD=
SECRET_KEY=

# ── AWS ─────────────────────────────────────────────────────────
# Region for Bedrock embeddings (Titan Embed Text v2) and agents.
AWS_REGION=eu-central-1

# ── File uploads (Service A) ────────────────────────────────────
UPLOAD_DIR=/home/ec2-user/personal-intelligence/uploads

# ── Microsoft Entra / Graph API (agents) ────────────────────────
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=https://adel-intelligence.com/auth/microsoft/callback
MS_TENANT=consumers

# ── MCP memory auth (agents → Service A) ────────────────────────
# These allow agents to obtain a Bearer token for the MCP server.
MCP_MEMORY_URL=https://adel-intelligence.com/mcp/mcp
MCP_MEMORY_CLIENT_ID=
MCP_MEMORY_REFRESH_TOKEN=

# ── Bedrock model (agents) ───────────────────────────────────────
BEDROCK_MODEL_ID=eu.amazon.nova-2-lite-v1:0

# ── Job agent ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@your-rds-endpoint.eu-central-1.rds.amazonaws.com/adel_intelligence
RAPIDAPI_KEY=
RAPIDAPI_HOST=jsearch.p.rapidapi.com
SCRAPER_DELAY_SECONDS=2.0
SCRAPER_MAX_RESULTS_PER_QUERY=20
NOTIFICATION_EMAIL=adel.haidar@outlook.com

# ── Content platform (PULSE / SIGNAL) ───────────────────────────
# Gemini API key for web research grounding (P2 topic intelligence).
GEMINI_API_KEY=
# Shared secret for internal job-trigger endpoints (/api/content/jobs/*).
INTERNAL_SECRET=
# S3 bucket + CloudFront distribution for generated post images and videos.
S3_CONTENT_BUCKET=personal-intelligence-content
CLOUDFRONT_BASE_URL=https://dXXXXXXXXXXXX.cloudfront.net
# Bedrock Haiku model for content text generation (optional override).
BEDROCK_HAIKU_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
# Nova Canvas image generation — NOT available in eu-central-1, default eu-west-1.
BEDROCK_IMAGE_REGION=eu-west-1
NOVA_CANVAS_MODEL_ID=amazon.nova-canvas-v1:0

# ── Private Internet platform ───────────────────────────────────
APP_NAME=Private Internet
# Public domain this instance is served from (no scheme).
APP_DOMAIN=your-domain.com
# Existing single-user data is assigned to this account by the
# multi-tenancy migration; also the first admin login.
SEED_ADMIN_EMAIL=admin@your-domain.com
# false → invite-only (accounts created via manage.py create-user)
REGISTRATION_OPEN=true
# 0 = unlimited
MAX_USERS=100
